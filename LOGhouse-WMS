<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LOG-House Corp. — WMS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>
    <style>
        :root{--bg-dark:#070a12;--sidebar-bg:#0f1420;--card-bg:rgba(255,255,255,.03);--card-border:rgba(255,255,255,.07);--text-main:#f8fafc;--text-muted:#94a3b8;--gradient-primary:linear-gradient(135deg,#22d3ee 0%,#0ea5e9 50%,#4338ca 100%);--gradient-success:linear-gradient(135deg,#34d399 0%,#059669 100%);--gradient-warning:linear-gradient(135deg,#fbbf24 0%,#d97706 100%);--gradient-danger:linear-gradient(135deg,#ef4444 0%,#b91c1c 100%);--accent-glow:rgba(34,211,238,.15)}
        *{box-sizing:border-box;font-family:'Inter',sans-serif;margin:0;padding:0;-webkit-font-smoothing:antialiased}
        h1,h2,h3,.brand-text{font-family:'Plus Jakarta Sans',sans-serif;font-weight:700}
        body{background-color:var(--bg-dark);color:var(--text-main);min-height:100vh;overflow-x:hidden}

        /* Login Screen */
        #login-screen{position:fixed;top:0;left:0;width:100vw;height:100vh;background:radial-gradient(circle at 80% 20%,#1e1b4b 0%,#070a12 100%);display:flex;justify-content:center;align-items:center;z-index:9999}
        .login-box{background:rgba(15,20,32,.75);backdrop-filter:blur(25px);border:1px solid var(--card-border);padding:45px 40px;border-radius:28px;width:100%;max-width:435px;box-shadow:0 25px 60px rgba(0,0,0,.6);text-align:center}
        .login-box h2{font-size:1.85rem;margin-bottom:6px;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
        .login-box .sys-label{color:#34d399;font-size:11px;text-transform:uppercase;letter-spacing:2px;font-weight:700;margin-bottom:25px;display:block}
        
        /* Layout */
        .app-wrapper{display:none}
        nav{width:280px;background-color:var(--sidebar-bg);padding:30px 20px;display:flex;flex-direction:column;position:fixed;height:100vh;border-right:1px solid var(--card-border);z-index:100;overflow-y:auto}
        .brand{display:flex;align-items:center;gap:12px;margin-bottom:30px;padding-left:10px}
        .brand i{font-size:1.4rem;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
        .brand-text{font-size:1.25rem;letter-spacing:-.5px;font-weight:800}
        .nav-item{padding:12px 16px;margin-bottom:6px;border-radius:12px;cursor:pointer;transition:all .3s;display:flex;align-items:center;gap:12px;color:var(--text-muted);font-size:10.5px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
        .nav-item i{font-size:14px}.nav-item:hover{color:var(--text-main);background:rgba(255,255,255,.03)}
        .nav-item.active{background:var(--gradient-primary);color:#fff;box-shadow:0 8px 20px rgba(14,165,233,.25)}
        .spv-only{border-left:3px solid #fbbf24}
        main{flex-grow:1;margin-left:280px;padding:35px}
        .view{display:none;animation:slideUp .5s ease}.view.active{display:block}
        @keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
        .top-bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:35px;flex-wrap:wrap;gap:10px}
        .top-bar h2{font-size:1.8rem;letter-spacing:-.5px}

        /* Components */
        .card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:24px;padding:30px;margin-bottom:25px;backdrop-filter:blur(10px)}
        .card h2{font-size:1.3rem;margin-bottom:20px;display:flex;align-items:center;gap:10px}
        .form-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
        .form-group{margin-bottom:20px}
        label{display:block;margin-bottom:8px;color:var(--text-muted);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
        input,select,textarea{width:100%;padding:16px 14px;background:rgba(0,0,0,.25);border:1px solid var(--card-border);border-radius:12px;color:var(--text-main);font-size:12px;transition:all .3s}
        input:focus,select:focus,textarea:focus{outline:none;border-color:#22d3ee;box-shadow:0 0 15px var(--accent-glow)}
        select option{background:var(--sidebar-bg);color:var(--text-main)}
        .btn{padding:13px 20px;border:none;border-radius:12px;cursor:pointer;font-size:11px;font-weight:700;transition:all .3s;display:inline-flex;align-items:center;gap:7px;text-transform:uppercase;letter-spacing:.5px}
        .btn-primary{background:var(--gradient-primary);color:#fff}.btn-success{background:var(--gradient-success);color:#fff}
        .btn-warning{background:var(--gradient-warning);color:#070a12}.btn-danger{background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2)}
        .btn-danger:hover{background:#ef4444;color:#fff}.btn-sm{padding:6px 12px;font-size:10px;border-radius:8px}.btn-xs{padding:4px 10px;font-size:9px;border-radius:6px}
        .table-container{overflow-x:auto;margin-top:15px;border-radius:16px;border:1px solid var(--card-border)}
        table{width:100%;border-collapse:collapse;font-size:11px;background:rgba(0,0,0,.1)}
        th{background:rgba(255,255,255,.02);text-align:left;padding:14px 8px;border-bottom:1px solid var(--card-border);color:var(--text-muted);font-weight:700;text-transform:uppercase;letter-spacing:.5px;font-size:9.5px;white-space:nowrap}
        td{padding:12px 8px;border-bottom:1px solid rgba(255,255,255,.02);vertical-align:middle;color:#e2e8f0;line-height:1.5;font-size:11px}
        tr:hover td{background:rgba(255,255,255,.01)}
        .badge{padding:4px 10px;border-radius:20px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.3px;display:inline-block;white-space:nowrap}
        .badge-success{background:rgba(52,211,153,.1);color:#34d399}.badge-warning{background:rgba(251,191,36,.1);color:#fbbf24}.badge-danger{background:rgba(239,68,68,.12);color:#f87171}
        .badge-info{background:rgba(59,130,246,.12);color:#60a5fa}
        
        /* WMS Specifics */
        .rack-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(45px,1fr));gap:6px}
        .rack-grid-large{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:10px}
        .rack-box{aspect-ratio:1;background:rgba(255,255,255,0.02);border:2px solid var(--card-border);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:var(--text-muted);cursor:pointer;position:relative;transition:all .2s}
        .rack-box:hover{transform:scale(1.1);z-index:2;box-shadow:0 4px 8px rgba(0,0,0,.3)}
        .rack-box.slot-empty{background:rgba(52,211,153,.05);border-color:rgba(52,211,153,.3);color:#34d399}
        .rack-box.slot-partial{background:rgba(251,191,36,.05);border-color:rgba(251,191,36,.3);color:#fbbf24}
        .rack-box.slot-full{background:rgba(239,68,68,.05);border-color:rgba(239,68,68,.3);color:#f87171}
        .rack-box-lg{background:rgba(52,211,153,.05);border:2px solid rgba(52,211,153,.3);border-radius:10px;padding:10px;text-align:center;cursor:pointer;min-height:90px;transition:.2s;color:var(--text-main)}
        .rack-box-lg.slot-partial{background:rgba(251,191,36,.05);border-color:rgba(251,191,36,.3)}
        .rack-box-lg.slot-full{background:rgba(239,68,68,.05);border-color:rgba(239,68,68,.3)}
        .product-badge{font-size:7px;position:absolute;bottom:2px;left:2px;right:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;background:rgba(0,0,0,.8);color:white;padding:1px 3px;border-radius:3px}
        .row-label{font-size:0.8rem;font-weight:bold;color:var(--text-muted);margin-bottom:8px}
        
        .scan-input{border:2px dashed #22d3ee;background:rgba(34,211,238,.05);font-family:monospace;font-size:1.1rem;color:var(--text-main)}
        .search-input{border:2px solid #34d399;background:rgba(52,211,153,.05);color:var(--text-main)}
        .qr-input{border:2px dashed #a78bfa;background:rgba(167,139,250,.05);font-family:monospace;font-size:1.1rem;color:var(--text-main)}
        
        .flex-row{display:flex;gap:20px;flex-wrap:wrap}
        .flex-1{flex:1;min-width:300px}
        .w-full{width:100%;justify-content:center}
        .justify-between{justify-content:space-between}
        .items-center{align-items:center}
        .mt-2{margin-top:20px}.mb-2{margin-bottom:20px}.mb-1{margin-bottom:10px}
        .text-muted{color:var(--text-muted)}.text-primary{color:#22d3ee}.text-success{color:#34d399}.text-danger{color:#f87171}.text-warning{color:#fbbf24}
        .fw-bold{font-weight:700}
        .d-none{display:none!important}
        
        .fb-config-zone{background:rgba(251,191,36,.04);border:1px solid rgba(251,191,36,.15);border-radius:16px;padding:20px}
        .fb-log{background:rgba(0,0,0,.3);border:1px solid var(--card-border);border-radius:10px;padding:12px 16px;margin-top:14px;max-height:180px;overflow-y:auto;font-family:'Courier New',monospace;font-size:10px;line-height:1.6;color:#94a3b8}
        
        .settings-grid{display:grid;grid-template-columns:350px 1fr;gap:25px}
        .settings-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:16px;padding:20px}
        .settings-card h3{font-size:14px;margin-bottom:15px;padding-bottom:10px;border-bottom:1px solid var(--card-border);color:#22d3ee;display:flex;align-items:center;gap:8px}
        .user-card{background:rgba(255,255,255,0.02);border:1px solid var(--card-border);border-radius:12px;padding:15px;margin-bottom:15px}
        .info-banner{background:rgba(34,211,238,.06);border:1px solid rgba(34,211,238,.15);padding:12px 16px;border-radius:12px;margin-bottom:18px;font-size:11px;color:#22d3ee}

        .modal{position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(7,10,18,.85);backdrop-filter:blur(8px);display:none;justify-content:center;align-items:flex-start;z-index:10000;overflow-y:auto;padding:30px}
        .modal-content{background:#0f1420;border:1px solid var(--card-border);border-radius:24px;padding:35px;width:100%;max-width:600px;box-shadow:0 20px 50px rgba(0,0,0,.5);animation:zoomIn .3s ease;margin-top:20px}
        @keyframes zoomIn{from{transform:scale(.9);opacity:0}to{transform:scale(1);opacity:1}}
        .modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:25px}
        .modal-header h3{font-size:1.3rem;color:#22d3ee}.modal-close{cursor:pointer;color:var(--text-muted);font-size:1.5rem;transition:.2s}.modal-close:hover{color:#f87171}

        @media(max-width:900px){nav{width:220px}main{margin-left:220px}.settings-grid{grid-template-columns:1fr}}
        @media(max-width:700px){nav{width:60px;padding:15px 8px;align-items:center}.brand-text,.nav-item span{display:none}.nav-item{justify-content:center;padding:12px}main{margin-left:60px}}
    </style>
</head>
<body>

<!-- ================= VIEW: LOGIN ================= -->
<div id="login-screen">
    <div class="login-box">
        <div style="font-size:36px;margin-bottom:20px;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent"><i class="fa-solid fa-warehouse"></i></div>
        <h2>LOGIN</h2>
        <div class="sys-label">Warehouse Management System</div>
        <div id="login-error" class="info-banner d-none" style="background:rgba(239,68,68,.1);color:#f87171;border-color:rgba(239,68,68,.2)"></div>
        <div class="form-group" style="text-align:left"><label>Username</label><input type="text" id="login-username" placeholder="Username" autocomplete="off"></div>
        <div class="form-group" style="text-align:left"><label>Password</label><input type="password" id="login-pass" placeholder="Masukkan password" onkeydown="if(event.key==='Enter')prosesLogin()"></div>
        <button class="btn btn-primary w-full" onclick="prosesLogin()">Masuk <i class="fa fa-arrow-right"></i></button>
        <p style="margin-top:20px;font-size:10px;color:rgba(148,163,184,.35)">spv/123 | operator/123</p>
    </div>
</div>

<!-- ================= APP: WMS ================= -->
<div id="app-wms" class="app-wrapper" style="display:none">
    <nav id="sidebar-wms">
        <div class="brand"><i class="fa-solid fa-warehouse"></i><span class="brand-text">LOG-House <span style="font-size:10px;color:#34d399;border:1px solid #34d399;padding:1px 6px;border-radius:6px">WMS</span></span></div>
        <div class="nav-item active" onclick="showView('wms-dashboard', this)"><i class="fa-solid fa-tachometer-alt"></i> <span>Dashboard</span></div>
        <div class="nav-item" onclick="showView('wms-inbound', this)"><i class="fa-solid fa-arrow-circle-down"></i> <span>Inbound</span></div>
        <div class="nav-item" onclick="showView('wms-outbound', this)"><i class="fa-solid fa-arrow-circle-up"></i> <span>Outbound</span></div>
        <div class="nav-item" onclick="showView('wms-rack', this)"><i class="fa-solid fa-cubes"></i> <span>Master Rak</span></div>
        <div class="nav-item" onclick="showView('wms-product', this)"><i class="fa-solid fa-coffee"></i> <span>Master Produk</span></div>
        <div class="nav-item" onclick="showView('wms-status', this)"><i class="fa-solid fa-tags"></i> <span>Master Status</span></div>
        <div class="nav-item" onclick="showView('wms-firebase', this)"><i class="fa-solid fa-cloud-arrow-up"></i> <span>Konfigurasi Cloud</span></div>
        <div class="nav-item spv-only" onclick="showView('wms-settings', this)"><i class="fa-solid fa-user-shield"></i> <span>Manajemen Akun</span></div>
        <button class="btn btn-danger" style="margin-top:auto;justify-content:center" onclick="prosesLogout()"><i class="fa-solid fa-power-off"></i> <span>Keluar</span></button>
    </nav>
    <main id="main-wms">
        <div class="top-bar">
            <h2 id="wms-view-title">Dashboard WMS</h2>
            <div id="user-badge-wms" style="font-weight:600;font-size:11px;padding:10px 18px;background:rgba(255,255,255,.04);border:1px solid var(--card-border);border-radius:30px;text-transform:uppercase"></div>
        </div>

        <div id="wms-dashboard" class="view active">
            <div class="flex-row mb-2">
                <div class="card flex-1" style="border-left:4px solid #22d3ee"><h2 style="color:#22d3ee;font-size:14px">Total Pallet</h2><h1 id="dash-total-pallet">0</h1></div>
                <div class="card flex-1" style="border-left:4px solid #34d399"><h2 style="color:#34d399;font-size:14px">Slot Terpakai</h2><h1 id="dash-slot-used">0</h1></div>
                <div class="card flex-1" style="border-left:4px solid #f87171"><h2 style="color:#f87171;font-size:14px">Slot Penuh</h2><h1 id="dash-slot-full">0</h1></div>
                <div class="card flex-1" style="border-left:4px solid #fbbf24"><h2 style="color:#fbbf24;font-size:14px">Slot Tersedia</h2><h1 id="dash-slot-avail">0</h1></div>
            </div>
            <div class="card">
                <div class="flex-row justify-between items-center mb-1"><h2>Peta Warehouse</h2><div><span class="badge badge-success">Kosong</span> <span class="badge badge-warning">Sebagian</span> <span class="badge badge-danger">Penuh</span></div></div>
                <div id="dash-rack-map"></div>
            </div>
        </div>

        <div id="wms-inbound" class="view">
            <div class="flex-row">
                <div style="flex:0 0 380px">
                    <div class="card"><h2>Scan & Input Inbound</h2>
                        <div class="form-group"><label>1. Scan QR Code Rak (Otomatis)</label><input type="text" id="inQrRack" class="qr-input" placeholder="Arahkan scanner QR ke Rak..." autofocus></div>
                        <div class="form-group"><label>2. Scan Barcode Produk</label><input type="text" id="inBarcode" class="scan-input" placeholder="Arahkan scanner barcode..."></div>
                        <div id="inParsedInfo" class="text-primary fw-bold mb-2" style="font-size:11px"></div>
                        <div class="form-group"><label>3. Info Produk & Status</label><select id="inProduct" class="mb-1"></select><select id="inStatus"></select></div>
                        <div class="form-group">
                            <label>4. Lokasi Penyimpanan</label>
                            <input type="text" id="inRack" list="rackList" class="search-input mb-1" placeholder="Ketik Rak (Misal: A)..." autocomplete="off">
                            <datalist id="rackList"></datalist>
                            <input type="text" id="inSlot" list="slotList" class="search-input" placeholder="Ketik Slot (Misal: 1a)..." autocomplete="off">
                            <datalist id="slotList"></datalist>
                        </div>
                        <div class="form-group">
                            <label>5. Nomor Pallet (Range)</label>
                            <div class="flex-row items-center">
                                <input type="number" id="inPalletStart" placeholder="Dari (XX)" min="1" value="1">
                                <span class="text-muted fw-bold" style="font-size:18px">-</span>
                                <input type="number" id="inPalletEnd" placeholder="Sampai (YY)" min="1" value="1">
                            </div>
                            <small class="text-muted" style="font-size:10px; margin-top:5px; display:block">Kosongkan slot di atas untuk auto-assign ke slot kosong pertama di rak.</small>
                        </div>
                        <button class="btn btn-primary w-full mt-2" onclick="submitInbound()"><i class="fa fa-check-circle"></i> SUBMIT PLOTTING</button>
                    </div>
                </div>
                <div class="flex-1">
                    <div class="card"><div class="flex-row justify-between items-center mb-1"><h2>Visualisasi Rak</h2><h2 class="text-primary" id="inVisTitle">Pilih Rak</h2></div><div id="inRackVisual" style="max-height:650px;overflow-y:auto"></div></div>
                </div>
            </div>
        </div>

        <div id="wms-outbound" class="view">
            <div class="flex-row">
                <div style="flex:0 0 350px">
                    <div class="card"><h2>Outbound Scan</h2>
                        <div class="form-group"><label>1. Scan Barcode Keluar</label><input type="text" id="outBarcode" class="scan-input" placeholder="Arahkan scanner..."></div>
                        <div id="outItemInfo" class="mb-2"></div>
                        <div class="form-group d-none" id="outVerifyCard"><label>2. Verifikasi Rak</label><input type="text" id="outVerifyRack" list="outRackList" class="search-input mb-1" placeholder="Scan/Ketik Rak..." autocomplete="off"><datalist id="outRackList"></datalist><div id="outVerifyResult" class="text-muted fw-bold mb-2" style="font-size:11px"></div><button class="btn btn-danger w-full d-none" id="btnOutbound" onclick="submitOutbound()"><i class="fa fa-truck-loading"></i> KONFIRMASI KELUAR</button></div>
                    </div>
                </div>
                <div class="flex-1">
                    <div class="card"><h2>Info Pengeluaran</h2><div id="outInfoPanel" class="text-center text-muted" style="padding:40px 0"><i class="fa fa-box-open fa-3x mb-2"></i><br>Scan barcode barang</div></div>
                </div>
            </div>
        </div>

        <div id="wms-rack" class="view"><div class="card"><div class="flex-row justify-between items-center mb-2"><h2>Master Rak</h2><button class="btn btn-primary" onclick="showModal('rackModal')"><i class="fa fa-plus"></i> Tambah Rak</button></div><div class="table-container"><table><thead><tr><th>ID Rak</th><th>Produk Utama</th><th>Jumlah Slot</th><th>Aksi</th></tr></thead><tbody id="rackTableBody"></tbody></table></div></div></div>
        <div id="wms-product" class="view"><div class="card"><div class="flex-row justify-between items-center mb-2"><h2>Master Produk</h2><button class="btn btn-primary" onclick="showModal('productModal')"><i class="fa fa-plus"></i> Tambah Produk</button></div><div class="table-container"><table><thead><tr><th>Kode</th><th>Nama Produk</th><th>Satuan</th><th>Berat/Unit</th><th>Aksi</th></tr></thead><tbody id="productTableBody"></tbody></table></div></div></div>
        <div id="wms-status" class="view"><div class="card"><div class="flex-row justify-between items-center mb-2"><h2>Master Status</h2><button class="btn btn-primary" onclick="showModal('statusModal')"><i class="fa fa-plus"></i> Tambah Status</button></div><div class="table-container"><table><thead><tr><th>Nama Status</th><th>Aksi</th></tr></thead><tbody id="statusTableBody"></tbody></table></div></div></div>

        <div id="wms-firebase" class="view"><div class="card fb-config-zone"><h2><i class="fa-solid fa-cloud-arrow-up text-primary"></i> Konfigurasi Cloud</h2><p class="text-muted mb-2">Hubungkan aplikasi WMS ke Firebase Realtime Database.</p><div class="form-group"><label>Database URL</label><input type="text" id="fb-url" placeholder="https://xxx-default-rtdb..."></div><div class="form-grid"><div class="form-group"><label>API Key</label><input type="text" id="fb-api" placeholder="AIzaSy..."></div><div class="form-group"><label>Project ID</label><input type="text" id="fb-project" placeholder="nama-project"></div></div><div class="form-group"><label>Auth Domain</label><input type="text" id="fb-auth" placeholder="nama-project.firebaseapp.com"></div><button class="btn btn-success" onclick="connectFirebase()"><i class="fa fa-plug"></i> Hubungkan</button><div id="fb-log" class="fb-log d-none mt-2"></div></div></div>

        <div id="wms-settings" class="view"><div class="card"><h2><i class="fa-solid fa-users-gear text-warning"></i> Manajemen Akun</h2><div class="settings-grid"><div class="settings-card"><h3><i class="fa fa-user-plus"></i> Tambah User</h3><form id="form-add-user"><div class="form-group"><label>Role</label><select id="usr-role"><option value="OPERATOR">Operator</option><option value="SPV">Supervisor</option></select></div><div class="form-group"><label>Username</label><input type="text" id="usr-name" required></div><div class="form-group"><label>Password</label><input type="text" id="usr-pass" required></div><button type="submit" class="btn btn-warning w-full" style="color:#fff">Simpan</button></form></div><div class="settings-card"><h3><i class="fa fa-list-check"></i> Daftar User</h3><div id="user-list-container"></div></div></div></div></div>
    </main>
</div>

<!-- MODALS -->
<div class="modal" id="rackModal"><div class="modal-content"><div class="modal-header"><h3 id="rackModalTitle">Tambah Rak</h3><span class="modal-close" onclick="closeModal('rackModal')">&times;</span></div><input type="hidden" id="editOldRackId"><div class="form-group"><label>ID Rak</label><input type="text" id="mRackId" placeholder="Contoh: A, K"></div><div class="form-group"><label>Produk Utama</label><input type="text" id="mRackProduct" placeholder="Contoh: Instant Coffee"></div><div class="form-group"><label>Daftar Slot (Pisahkan koma)</label><textarea id="mRackSlots" rows="4" placeholder="1a, 1b, 2a..."></textarea></div><button class="btn btn-primary w-full" onclick="saveRack()">Simpan</button></div></div>
<div class="modal" id="productModal"><div class="modal-content"><div class="modal-header"><h3 id="productModalTitle">Tambah Produk</h3><span class="modal-close" onclick="closeModal('productModal')">&times;</span></div><input type="hidden" id="editOldProdId"><div class="form-grid"><div class="form-group"><label>Kode Produk</label><input type="text" id="mProdId" placeholder="IC01"></div><div class="form-group"><label>Nama Produk</label><input type="text" id="mProdName" placeholder="Instant Coffee"></div></div><div class="form-grid"><div class="form-group"><label>Satuan</label><input type="text" id="mProdUnit" placeholder="Karton"></div><div class="form-group"><label>Berat/Unit</label><input type="number" step="0.01" id="mProdWeight" placeholder="5.5"></div></div><button class="btn btn-primary w-full mt-2" onclick="saveProduct()">Simpan</button></div></div>
<div class="modal" id="statusModal"><div class="modal-content"><div class="modal-header"><h3>Tambah Status</h3><span class="modal-close" onclick="closeModal('statusModal')">&times;</span></div><input type="hidden" id="editOldStatus"><div class="form-group"><label>Nama Status</label><input type="text" id="mStatusName" placeholder="OK, BO, HOLD"></div><button class="btn btn-primary w-full" onclick="saveStatus()">Simpan</button></div></div>
<div class="modal" id="slotDetailModal"><div class="modal-content"><div class="modal-header"><h3 id="slotDetailTitle">Detail Slot</h3><span class="modal-close" onclick="closeModal('slotDetailModal')">&times;</span></div><div id="slotDetailBody"></div></div></div>

<script>
    // ======================= CORE & AUTH =======================
    let currentUser = null;
    const MAX_PALLET = 4;

    if(!localStorage.getItem('users')) {
        localStorage.setItem('users', JSON.stringify({
            'spv': {password:'123', role:'SPV'},
            'operator': {password:'123', role:'OPERATOR'}
        }));
    }
    const getUsers = () => JSON.parse(localStorage.getItem('users'));
    const saveUsers = (u) => localStorage.setItem('users', JSON.stringify(u));

    function prosesLogin() {
        let u = document.getElementById('login-username').value.trim().toLowerCase();
        let p = document.getElementById('login-pass').value;
        let users = getUsers();
        if(users[u] && users[u].password === p) {
            currentUser = {username: u, role: users[u].role};
            document.getElementById('login-screen').style.display = 'none';
            document.getElementById('app-wms').style.display = 'flex';
            initWMS();
        } else {
            let e = document.getElementById('login-error'); e.innerText = "Username atau Password salah!"; e.classList.remove('d-none');
        }
    }

    function prosesLogout() { currentUser=null; document.getElementById('app-wms').style.display='none'; document.getElementById('login-screen').style.display='flex'; document.getElementById('login-username').value=''; document.getElementById('login-pass').value=''; }

    // ======================= WMS LOGIC =======================
    if(!localStorage.getItem('wms_statuses')) localStorage.setItem('wms_statuses', JSON.stringify(['OK', 'BO', 'HOLD']));
    if(!localStorage.getItem('wms_products')) localStorage.setItem('wms_products', JSON.stringify([ {id:'IC01', name:'Instant Coffee 200g', unit:'Karton', weight:'5.5'}, {id:'IC02', name:'Instant Coffee 500g', unit:'Karton', weight:'8.0'} ]));
    if(!localStorage.getItem('wms_racks')) {
        let initRacks = [];
        ['A','B','C','D','E','F','G','H','I','J'].forEach(r => initRacks.push({ id: r, product: 'Instant Coffee', slots: generateDefaultSlots() }));
        localStorage.setItem('wms_racks', JSON.stringify(initRacks));
    }
    if(!localStorage.getItem('wms_db')) {
        let initDb = {}; ['A','B','C','D','E','F','G','H','I','J'].forEach(r => initDb[r] = {});
        localStorage.setItem('wms_db', JSON.stringify(initDb));
    }

    function generateDefaultSlots() { let s=[]; for(let r=1; r<=4; r++) { for(let c of ['a','b','c','d','e','f','g','h','i','j','k','l','m']) { s.push(r+c); } } return s; }
    const getStatuses = () => JSON.parse(localStorage.getItem('wms_statuses'));
    const saveStatuses = (s) => localStorage.setItem('wms_statuses', JSON.stringify(s));
    const getProducts = () => JSON.parse(localStorage.getItem('wms_products'));
    const saveProducts = (p) => localStorage.setItem('wms_products', JSON.stringify(p));
    const getRacks = () => JSON.parse(localStorage.getItem('wms_racks'));
    const saveRacks = (r) => localStorage.setItem('wms_racks', JSON.stringify(r));
    const getDb = () => JSON.parse(localStorage.getItem('wms_db'));
    const saveDb = (db) => localStorage.setItem('wms_db', JSON.stringify(db));

    let currentOutboundData = null;

    function initWMS() {
        document.getElementById('user-badge-wms').innerHTML = `<i class="fa fa-user"></i> ${currentUser.username.toUpperCase()} (${currentUser.role})`;
        document.querySelectorAll('#sidebar-wms .spv-only').forEach(el => el.style.display = currentUser.role === 'SPV' ? 'flex' : 'none');
        populateDropdowns();
        showView('wms-dashboard', document.querySelector('#sidebar-wms .nav-item'));
    }

    function showView(viewId, el) {
        document.querySelectorAll('#main-wms .view').forEach(v => v.classList.remove('active'));
        document.getElementById(viewId).classList.add('active');
        document.querySelectorAll('#sidebar-wms .nav-item').forEach(n => n.classList.remove('active'));
        if(el) el.classList.add('active');

        if(viewId === 'wms-dashboard') renderDashboard();
        if(viewId === 'wms-inbound') { clearInboundForm(); renderInboundVisual(); }
        if(viewId === 'wms-outbound') resetOutboundForm();
        if(viewId === 'wms-rack') renderRackTable();
        if(viewId === 'wms-product') renderProductTable();
        if(viewId === 'wms-status') renderStatusTable();
        if(viewId === 'wms-settings') renderUserList();
    }

    function showModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }

    function populateDropdowns() {
        let racks = getRacks().map(r => r.id), rackHtml = '';
        racks.forEach(r => rackHtml += `<option value="Rak ${r}">`);
        document.getElementById('rackList').innerHTML = rackHtml;
        document.getElementById('outRackList').innerHTML = rackHtml;
        let prods = getProducts(), prodHtml = '<option value="">-- Pilih --</option>';
        prods.forEach(p => prodHtml += `<option value="${p.id}">${p.id} - ${p.name}</option>`);
        document.getElementById('inProduct').innerHTML = prodHtml;
        let stats = getStatuses(), statHtml = '';
        stats.forEach(s => statHtml += `<option value="${s}">${s}</option>`);
        document.getElementById('inStatus').innerHTML = statHtml;
        updateSlotDatalist('');
    }
    
    function updateSlotDatalist(rackId) {
        let racks = getRacks(), rack = racks.find(r => r.id === rackId); let slotHtml = '';
        if(rack) { rack.slots.forEach(s => slotHtml += `<option value="${rackId}.${s}">`); } else { racks.forEach(r => r.slots.forEach(s => slotHtml += `<option value="${r.id}.${s}">`)); }
        document.getElementById('slotList').innerHTML = slotHtml;
    }
    
    // QR & Barcode Scanner Listeners
    document.getElementById('inQrRack').addEventListener('keypress', function(e) { 
        if(e.key==='Enter') { 
            e.preventDefault(); 
            let rawScan = this.value.trim().toUpperCase();
            // Extract Rack ID from QR (e.g., "RAK-A", "RAK A", or just "A")
            let rackId = rawScan.replace(/RAK[\s\-]*/i, '').trim();
            
            let racks = getRacks().map(r => r.id);
            if(racks.includes(rackId)) {
                document.getElementById('inRack').value = "Rak " + rackId;
                updateSlotDatalist(rackId);
                renderInboundVisual();
                document.getElementById('inBarcode').focus(); // Move focus to barcode
            } else {
                alert("Rak " + rawScan + " tidak ditemukan!");
            }
            this.value = ''; // Clear QR input for next scan
        } 
    });

    document.getElementById('inRack').addEventListener('input', function() { let val = this.value.replace('Rak ','').toUpperCase(); let rid = getRacks().map(r=>r.id).includes(val) ? val : ''; updateSlotDatalist(rid); renderInboundVisual(); });

    function parseBarcode(code) { if(!code || code.length < 7) return null; try { let type = code.charAt(0)==='P' ? 'Produksi' : 'Unknown'; let tower = code.charAt(1)==='A' ? 'Tower 1' : 'Tower 2'; let batch = code.substring(2, 5); return {type, tower, batch, raw:code}; } catch(e) { return null; } }

    document.getElementById('inBarcode').addEventListener('keypress', function(e) { if(e.key==='Enter') { e.preventDefault(); let parsed = parseBarcode(this.value); if(parsed) document.getElementById('inParsedInfo').innerHTML = `<i class="fa fa-check-circle text-success"></i> Tipe: <b>${parsed.type}</b> | Tower: <b>${parsed.tower}</b> | Batch: <b>${parsed.batch}</b>`; else document.getElementById('inParsedInfo').innerHTML = "<span class='text-danger'>Format barcode tidak dikenali</span>"; }});
    
    function clearInboundForm() { document.getElementById('inQrRack').value=''; document.getElementById('inBarcode').value=''; document.getElementById('inParsedInfo').innerHTML=''; document.getElementById('inRack').value=''; document.getElementById('inSlot').value=''; document.getElementById('inPalletStart').value=1; document.getElementById('inPalletEnd').value=1; updateSlotDatalist(''); }

    function renderInboundVisual() {
        let db = getDb(), racks = getRacks().map(r => r.id); let rackVal = document.getElementById('inRack').value.replace('Rak ','').toUpperCase(); let selRack = racks.includes(rackVal) ? rackVal : null;
        document.getElementById('inVisTitle').innerText = selRack ? `Rak ${selRack}` : 'Pilih Rak';
        if(!selRack) { document.getElementById('inRackVisual').innerHTML = '<div class="text-center text-muted p-5"><i class="fas fa-hand-pointer fa-3x mb-3"></i><br>Scan QR Rak atau ketik manual.</div>'; return; }
        if(!db[selRack]) db[selRack] = {}; let html = '', rackObj = getRacks().find(r => r.id === selRack); if(!rackObj) return;
        let groupedSlots = {}; rackObj.slots.forEach(s => { let rowNum = s.match(/^\d+/)?s.match(/^\d+/)[0]:'Other'; if(!groupedSlots[rowNum]) groupedSlots[rowNum]=[]; groupedSlots[rowNum].push(s); });
        for(let rowNum in groupedSlots) { html += `<div class="row-label mt-2">Baris ${rowNum}</div><div class="rack-grid-large">`; groupedSlots[rowNum].forEach(slot => { let items = db[selRack][slot]||[], isFull = items.length>=MAX_PALLET; let sc = items.length===0?'slot-empty':(items.length<MAX_PALLET?'slot-partial':'slot-full'); let pl = items.map(i=>`<span class="badge badge-info me-1 mb-1" style="font-size:9px">${i.pallet}</span>`).join(' '); html += `<div class="rack-box-lg ${sc}" onclick="document.getElementById('inSlot').value='${selRack}.${slot}'"><strong>${selRack}.${slot}</strong> <span class="badge ${isFull?'badge-danger':'badge-success'}" style="font-size:9px">${items.length}/${MAX_PALLET}</span><div style="min-height:25px; margin-top:5px">${pl}</div></div>`; }); html += '</div>'; }
        document.getElementById('inRackVisual').innerHTML = html;
    }

    function submitInbound() {
        let barcode = document.getElementById('inBarcode').value; 
        let rackVal = document.getElementById('inRack').value.replace('Rak ','').toUpperCase(); 
        let slotVal = document.getElementById('inSlot').value.split('.').pop().toLowerCase().trim(); 
        let productId = document.getElementById('inProduct').value; 
        let status = document.getElementById('inStatus').value;
        let palletStart = parseInt(document.getElementById('inPalletStart').value) || 1;
        let palletEnd = parseInt(document.getElementById('inPalletEnd').value) || palletStart;

        if(palletStart > palletEnd) { let temp = palletStart; palletStart = palletEnd; palletEnd = temp; } // Swap if reversed

        let racks = getRacks(), rackObj = racks.find(r => r.id === rackVal);
        if(!barcode || !rackVal || !productId || isNaN(palletStart) || isNaN(palletEnd)) { alert("Harap lengkapi Barcode, Rak, Produk, dan Range Pallet!"); return; }
        if(!rackObj) { alert("Rak tidak valid!"); return; }
        
        let db = getDb();
        if(!db[rackVal]) db[rackVal] = {};

        let palletsToAdd = palletEnd - palletStart + 1;
        let addedCount = 0;

        // Auto-assign slot if empty
        if(!slotVal) {
            for(let s of rackObj.slots) {
                let itemsInSlot = db[rackVal][s] || [];
                let availableSpace = MAX_PALLET - itemsInSlot.length;
                if(availableSpace > 0) {
                    slotVal = s;
                    document.getElementById('inSlot').value = rackVal + '.' + s; // Update UI
                    break;
                }
            }
            if(!slotVal) { alert(`Rak ${rackVal} penuh! Tidak ada slot tersedia.`); return; }
        }

        if(!rackObj.slots.includes(slotVal)) { alert(`Slot ${slotVal} tidak ada di Rak ${rackVal}!`); return; }
        
        if(!db[rackVal][slotVal]) db[rackVal][slotVal] = [];
        let currentItems = db[rackVal][slotVal];
        let availableSpace = MAX_PALLET - currentItems.length;

        if(palletsToAdd > availableSpace) {
            if(!confirm(`Slot ${rackVal}.${slotVal} hanya tersisa ${availableSpace} ruang, tapi Anda memasukkan ${palletsToAdd} pallet. Tetap lanjutkan mengisi ${availableSpace} pallet?`)) return;
            palletEnd = palletStart + availableSpace - 1; // Cap the end
        }

        let prodObj = getProducts().find(p => p.id === productId);
        let parsed = parseBarcode(barcode);

        for(let i = palletStart; i <= palletEnd; i++) {
            currentItems.push({ 
                barcode, 
                pallet: String(i), 
                productId, 
                productName: prodObj ? prodObj.name : 'Unknown', 
                status, 
                batch: parsed ? parsed.batch : '-', 
                unit: prodObj ? prodObj.unit : '-', 
                weight: prodObj ? prodObj.weight : '-',
                timestamp: new Date().toLocaleString('id-ID') 
            });
            addedCount++;
        }

        saveDb(db); 
        alert(`✅ Sukses! ${addedCount} Pallet (No. ${palletStart} - ${palletStart + addedCount - 1}) masuk ke Rak ${rackVal} Slot ${slotVal}`);
        
        // Reset partially
        document.getElementById('inBarcode').value = ''; 
        document.getElementById('inParsedInfo').innerHTML = ''; 
        document.getElementById('inPalletStart').value = 1;
        document.getElementById('inPalletEnd').value = 1;
        renderInboundVisual();
    }

    // Dashboard & Outbound Logic (Same as before)
    function renderDashboard() {
        let db = getDb(), racks = getRacks(), totalPallets = 0, totalSlotsUsed = 0, fullSlots = 0;
        let mapHtml = '<div class="flex-row" style="flex-wrap:wrap">';
        racks.forEach(rackObj => {
            let rack = rackObj.id, rackTotal = 0, isRackFull = true, slotsHtml = '';
            if(!db[rack]) db[rack] = {};
            let groupedSlots = {};
            rackObj.slots.forEach(s => { let rowNum = s.match(/^\d+/) ? s.match(/^\d+/)[0] : 'Other'; if(!groupedSlots[rowNum]) groupedSlots[rowNum] = []; groupedSlots[rowNum].push(s); });
            for(let rowNum in groupedSlots) {
                groupedSlots[rowNum].forEach(slot => {
                    let items = db[rack][slot] || []; rackTotal += items.length;
                    let slotStatusClass = items.length===0 ? 'slot-empty' : (items.length < MAX_PALLET ? 'slot-partial' : 'slot-full');
                    if(items.length < MAX_PALLET) isRackFull = false; if(items.length >= MAX_PALLET) fullSlots++; if(items.length > 0) totalSlotsUsed++;
                    let prodBadge = items.length > 0 ? `<div class="product-badge">${(items[0].productName||'').substring(0,5)}</div>` : '';
                    slotsHtml += `<div class="rack-box ${slotStatusClass}" onclick="showSlotDetail('${rack}','${slot}')">${slot} ${prodBadge}</div>`;
                });
            }
            totalPallets += rackTotal;
            mapHtml += `<div style="flex:1; min-width:250px; margin-bottom:20px"><div class="card" style="padding:0; overflow:hidden"><div style="padding:12px; background:rgba(255,255,255,0.03); border-bottom:1px solid var(--card-border); display:flex; justify-content:space-between"><strong>RAK ${rack}</strong><span class="badge badge-info">${rackObj.product}</span><span class="badge badge-warning">${rackTotal} Pallet</span></div><div style="padding:15px" class="rack-grid">${slotsHtml}</div></div></div>`;
        });
        mapHtml += '</div>'; saveDb(db);
        document.getElementById('dash-rack-map').innerHTML = mapHtml;
        let totalAvail = (racks.reduce((acc, r) => acc + r.slots.length, 0)) - fullSlots;
        document.getElementById('dash-total-pallet').innerText = totalPallets;
        document.getElementById('dash-slot-used').innerText = totalSlotsUsed;
        document.getElementById('dash-slot-full').innerText = fullSlots;
        document.getElementById('dash-slot-avail').innerText = totalAvail;
    }

    function showSlotDetail(rackId, slotId) {
        let db = getDb(), items = db[rackId] ? db[rackId][slotId] || [] : [];
        document.getElementById('slotDetailTitle').innerText = `Isi Slot: Rak ${rackId} - ${slotId}`;
        if(items.length === 0) { document.getElementById('slotDetailBody').innerHTML = '<div class="text-center text-muted p-5"><i class="fas fa-box-open fa-3x mb-3"></i><br>Slot ini kosong.</div>'; } 
        else {
            let listHtml = ''; items.forEach(item => { let sc = item.status==='OK'?'badge-success':(item.status==='HOLD'?'badge-warning':'badge-danger'); listHtml += `<div class="user-card" style="display:flex; justify-content:space-between; align-items:center"><div><strong class="text-primary">${item.productName}</strong> <small class="text-muted">(${item.productId})</small><br><small>Pallet: <b>${item.pallet}</b> | Batch: ${item.batch||'-'}</small></div><span class="badge ${sc}">${item.status}</span></div>`; });
            document.getElementById('slotDetailBody').innerHTML = listHtml;
        }
        showModal('slotDetailModal');
    }

    function resetOutboundForm() { document.getElementById('outBarcode').value=''; document.getElementById('outItemInfo').innerHTML=''; document.getElementById('outVerifyCard').classList.add('d-none'); document.getElementById('btnOutbound').classList.add('d-none'); document.getElementById('outVerifyRack').value=''; currentOutboundData=null; document.getElementById('outInfoPanel').innerHTML='<div class="text-muted text-center" style="padding:40px 0"><i class="fas fa-box-open fa-3x mb-2"></i><br>Scan barcode barang</div>'; }

    document.getElementById('outBarcode').addEventListener('keypress', function(e) {
        if(e.key==='Enter') { e.preventDefault(); let barcode = this.value, db = getDb(), found = null; 
            for(let rackObj of getRacks()) { let rack = rackObj.id; if(!db[rack]) continue; for(let slot in db[rack]) { for(let i=0; i<db[rack][slot].length; i++) { if(db[rack][slot][i].barcode === barcode) { found = {rack, slot, index: i, data: db[rack][slot][i]}; break; } } if(found) break; } if(found) break; }
            if(found) { currentOutboundData = found; document.getElementById('outItemInfo').innerHTML = `<div class="info-banner" style="background:rgba(52,211,153,.1);color:#34d399;border-color:rgba(52,211,153,.2)"><strong>Ditemukan!</strong><br>Rak: <b>${found.rack}</b> | Slot: <b>${found.slot}</b><br>Produk: <b>${found.data.productName}</b> | Pallet: <b>${found.data.pallet}</b></div>`; document.getElementById('outVerifyCard').classList.remove('d-none'); document.getElementById('outInfoPanel').innerHTML = `<h4 class="text-danger">Rak ${found.rack} - ${found.slot}</h4><p>${found.data.productName}</p>`; } else { alert("❌ Barang tidak ditemukan!"); resetOutboundForm(); }
        }
    });

    document.getElementById('outVerifyRack').addEventListener('input', function() { if(!currentOutboundData) return; let val = this.value.replace('Rak ','').toUpperCase(); let btn = document.getElementById('btnOutbound'), res = document.getElementById('outVerifyResult'); if(val === currentOutboundData.rack) { res.innerHTML = "<span class='text-success'><i class='fa fa-check-circle'></i> Cocok!</span>"; btn.classList.remove('d-none'); } else { res.innerHTML = `<span class='text-danger'>Harus Rak ${currentOutboundData.rack}</span>`; btn.classList.add('d-none'); } });

    function submitOutbound() { if(!currentOutboundData) return; let val = document.getElementById('outVerifyRack').value.replace('Rak ','').toUpperCase(); if(val !== currentOutboundData.rack) { alert("Gagal! Rak tidak sesuai."); return; } let db = getDb(); db[currentOutboundData.rack][currentOutboundData.slot].splice(currentOutboundData.index, 1); if(db[currentOutboundData.rack][currentOutboundData.slot].length === 0) delete db[currentOutboundData.rack][currentOutboundData.slot]; saveDb(db); alert("✅ Outbound berhasil!"); resetOutboundForm(); renderDashboard(); }

    // Master Data CRUD
    function renderRackTable() { let racks = getRacks(), html = ''; racks.forEach(r => html += `<tr><td><strong>${r.id}</strong></td><td>${r.product}</td><td>${r.slots.length}</td><td><button class="btn btn-warning btn-xs" onclick="editRack('${r.id}')"><i class="fa fa-edit"></i></button> <button class="btn btn-danger btn-xs" onclick="deleteRack('${r.id}')"><i class="fa fa-trash"></i></button></td></tr>`); document.getElementById('rackTableBody').innerHTML = html || '<tr><td colspan="4" class="text-center text-muted">Tidak ada data</td></tr>'; }
    function editRack(id) { let r = getRacks().find(x => x.id === id); if(r) { document.getElementById('editOldRackId').value = r.id; document.getElementById('mRackId').value = r.id; document.getElementById('mRackProduct').value = r.product; document.getElementById('mRackSlots').value = r.slots.join(', '); showModal('rackModal'); } }
    function saveRack() { let id = document.getElementById('mRackId').value.toUpperCase(), prod = document.getElementById('mRackProduct').value, slotsStr = document.getElementById('mRackSlots').value, oldId = document.getElementById('editOldRackId').value; if(!id || !slotsStr) return; let slots = slotsStr.split(',').map(s => s.trim().toLowerCase()); let racks = getRacks(); if(oldId) { let idx = racks.findIndex(r => r.id === oldId); if(idx !== -1) racks[idx] = {id, product: prod, slots}; } else { if(racks.find(r => r.id === id)) { alert('Sudah ada!'); return; } racks.push({id, product: prod, slots}); let db = getDb(); db[id]={}; saveDb(db); } saveRacks(racks); closeModal('rackModal'); renderRackTable(); populateDropdowns(); }
    function deleteRack(id) { if(!confirm(`Hapus Rak ${id}?`)) return; saveRacks(getRacks().filter(r => r.id !== id)); let db = getDb(); delete db[id]; saveDb(db); renderRackTable(); populateDropdowns(); }

    function renderProductTable() { let prods = getProducts(), html = ''; prods.forEach(p => html += `<tr><td><strong>${p.id}</strong></td><td>${p.name}</td><td>${p.unit||'-'}</td><td>${p.weight||'-'}</td><td><button class="btn btn-warning btn-xs" onclick="editProduct('${p.id}')"><i class="fa fa-edit"></i></button> <button class="btn btn-danger btn-xs" onclick="deleteProduct('${p.id}')"><i class="fa fa-trash"></i></button></td></tr>`); document.getElementById('productTableBody').innerHTML = html || '<tr><td colspan="5" class="text-center text-muted">Tidak ada data</td></tr>'; }
    function editProduct(id) { let p = getProducts().find(x => x.id === id); if(p) { document.getElementById('editOldProdId').value = p.id; document.getElementById('mProdId').value = p.id; document.getElementById('mProdName').value = p.name; document.getElementById('mProdUnit').value = p.unit; document.getElementById('mProdWeight').value = p.weight; showModal('productModal'); } }
    function saveProduct() { let id = document.getElementById('mProdId').value, name = document.getElementById('mProdName').value, unit = document.getElementById('mProdUnit').value, weight = document.getElementById('mProdWeight').value, oldId = document.getElementById('editOldProdId').value; if(!id || !name) return; let prods = getProducts(); if(oldId) { let idx = prods.findIndex(p => p.id === oldId); if(idx !== -1) prods[idx] = {id, name, unit, weight}; } else { if(prods.find(p => p.id === id)) { alert('Sudah ada!'); return; } prods.push({id, name, unit, weight}); } saveProducts(prods); closeModal('productModal'); renderProductTable(); populateDropdowns(); }
    function deleteProduct(id) { if(!confirm(`Hapus ${id}?`)) return; saveProducts(getProducts().filter(p => p.id !== id)); renderProductTable(); populateDropdowns(); }

    function renderStatusTable() { let stats = getStatuses(), html = ''; stats.forEach(s => html += `<tr><td><strong>${s}</strong></td><td><button class="btn btn-danger btn-xs" onclick="deleteStatus('${s}')"><i class="fa fa-trash"></i></button></td></tr>`); document.getElementById('statusTableBody').innerHTML = html || '<tr><td colspan="2" class="text-center text-muted">Tidak ada data</td></tr>'; }
    function saveStatus() { let name = document.getElementById('mStatusName').value, old = document.getElementById('editOldStatus').value; if(!name) return; let stats = getStatuses(); if(old) { let idx = stats.indexOf(old); if(idx !== -1) stats[idx] = name; } else { if(stats.includes(name)) { alert('Sudah ada!'); return; } stats.push(name); } saveStatuses(stats); closeModal('statusModal'); renderStatusTable(); populateDropdowns(); document.getElementById('mStatusName').value = ''; }
    function deleteStatus(s) { if(!confirm(`Hapus ${s}?`)) return; saveStatuses(getStatuses().filter(x => x !== s)); renderStatusTable(); populateDropdowns(); }

    // User Management
    function renderUserList() {
        let users = getUsers(); let html = '';
        for(let u in users) {
            let role = users[u].role; let badge = role === 'SPV' ? 'badge-warning' : 'badge-success';
            html += `<div class="user-card"><div style="display:flex; justify-content:space-between; align-items:center"><strong style="font-size:14px">${u}</strong><span class="badge ${badge}">${role}</span></div></div>`;
        }
        document.getElementById('user-list-container').innerHTML = html;
    }
    document.getElementById('form-add-user').addEventListener('submit', function(e) { 
        e.preventDefault(); 
        let roleInput = document.getElementById('usr-role').value; let nameInput = document.getElementById('usr-name').value.trim().toLowerCase(); let passInput = document.getElementById('usr-pass').value;
        if(!nameInput || !passInput) { alert("Isi username & password!"); return; }
        let users = getUsers(); if(users[nameInput]) { alert("Username sudah ada!"); return; }
        users[nameInput] = { password: passInput, role: roleInput }; saveUsers(users); renderUserList();
        document.getElementById('usr-name').value = ''; document.getElementById('usr-pass').value = ''; alert("User berhasil ditambahkan!");
    });

    // Firebase Config Logic
    function connectFirebase() {
        let url = document.getElementById('fb-url').value; let api = document.getElementById('fb-api').value; let project = document.getElementById('fb-project').value; let auth = document.getElementById('fb-auth').value;
        if(!url || !api || !project) { alert("Harap lengkapi Database URL, API Key, dan Project ID!"); return; }
        try {
            if(!firebase.apps.length) { firebase.initializeApp({ apiKey: api, authDomain: auth, databaseURL: url, projectId: project }); }
            alert("Konfigurasi Firebase WMS berhasil disimpan!");
            localStorage.setItem('fb_config_wms', JSON.stringify({url, api, project, auth}));
        } catch(e) { alert("Gagal menghubungkan Firebase: " + e.message); }
    }

</script>
